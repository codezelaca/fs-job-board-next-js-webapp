# Database Configuration
# Update this with your actual database connection string
DATABASE_URL="postgresql://user:password@localhost:5432/devjobs-db"

# Authentication
# Generate a secret using: openssl rand -base64 32
# This is required by NextAuth / Auth.js
AUTH_SECRET="your-generated-auth-secret-here"

# Application URL
# Used for email links and callbacks
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Email Integration (Resend)
# Required for sending password reset emails
RESEND_API_KEY="re_your_resend_api_key_here"
